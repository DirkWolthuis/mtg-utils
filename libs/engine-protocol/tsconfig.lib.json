{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc/libs/engine-protocol",
    "tsBuildInfoFile": "../../dist/out-tsc/libs/engine-protocol/.tsbuildinfo",
    "declaration": true,
    "composite": true,
    "rootDir": "src",
    "types": ["node"]
  },
  "references": [{ "path": "../engine-core/tsconfig.lib.json" }],
  "include": ["src/**/*.ts"],
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx"
  ]
}
