{
  "name": "mtg-util-host",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/hosts/mtg-util-host/src",
  "tags": ["host", "app"],
  "targets": {
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "mtg-util-host:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "mtg-util-host:build",
        "port": 8888,
        "spa": true
      }
    },
    "serve": {
      "options": {}
    }
  }
}
